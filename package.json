{
  "name": "@goodpie/js-build-benchmarker",
  "description": "A CLI tool to benchmark and compare JavaScript build tools",
  "author": "Brandyn Britton",
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/goodpie/js-build-benchmarker.git"
  },
  "version": "1.0.7",
  "type": "module",
  "bin": {
    "js-build-benchmarker": "./dist/index.js"
  },
  "scripts": {
    "build": "bun build ./index.ts --outdir ./dist --target node && chmod +x ./dist/index.js",
    "start": "bun run ./index.ts"
  },
  "dependencies": {
    "@inquirer/checkbox": "^4.1.4",
    "@inquirer/prompts": "^7.4.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "bun-types": "latest",
    "typescript": "^5.3.3"
  },
  "bugs": {
    "url": "https://github.com/goodpie/js-build-benchmarker/issues"
  },
  "homepage": "https://github.com/goodpie/js-build-benchmarker#readme",
  "main": "dist/index.js",
  "keywords": [
    "\"benchmark\"",
    "\"build-tools\"",
    "\"webpack\"",
    "\"esbuild\"",
    "\"vite\"",
    "\"rollup\""
  ]
}
